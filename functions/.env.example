# Cloud Functions プロキシの環境変数サンプル
# 使い方: cp .env.example .env して値を埋める
# .env はコミット対象外（ルート .gitignore で除外済み）

# LINE Developers コンソール → 対象チャネル → 基本設定 → チャネルシークレット
LINE_CHANNEL_SECRET=

# GAS スクリプトエディタ → デプロイ → ウェブアプリURL（/exec で終わる）
GAS_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/exec

# プロキシ↔GAS 間の共有秘密。GAS 側 Script Property `PROXY_SHARED_SECRET` と同じ値にする
# 推奨生成: openssl rand -hex 32
PROXY_SHARED_SECRET=
